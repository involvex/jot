{
	"name": "@involvex/jot",
	"version": "0.1.0",
	"description": "A Bun-powered interactive CLI note-taking application",
	"repository": "https://github.com/involvex/jot",
	"license": "MIT",
	"author": "involvex",
	"type": "module",
	"bin": {
		"jot": "dist/src/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"prebuild": "bun run format && bun run lint:fix && bun run typecheck",
		"build": "tsc",
		"dev": "bun run src/cli.tsx",
		"format": "prettier --write .",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"test": "prettier --check . && xo && ava",
		"typecheck": "tsc --noEmit"
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@involvex/prettier-config",
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"dependencies": {
		"clipboardy": "^5.3.1",
		"date-fns": "^4.1.0",
		"ink": "^7.1.0",
		"ink-text-input": "^6.0.0",
		"meow": "^14.1.0",
		"nanoid": "^5.1.7",
		"react": "^19.2.7"
	},
	"devDependencies": {
		"@eslint/js": "latest",
		"@involvex/prettier-config": "0.0.5",
		"@types/node": "^26.0.0",
		"@types/react": "^19.2.17",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint": "10.5.0",
		"eslint-config-xo-react": "^0.30.1",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^7.1.1",
		"ink-testing-library": "^3.0.0",
		"jiti": "2.7.0",
		"prettier": "3.8.4",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-packagejson": "^3.0.0",
		"prettier-plugin-sort-imports": "^1.8.10",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"typescript-eslint": "8.61.1",
		"xo": "^0.53.1"
	},
	"engines": {
		"node": ">=16"
	}
}
